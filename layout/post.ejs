<%
const categoryList = page.categories && page.categories.toArray ? page.categories.toArray() : (Array.isArray(page.categories) ? page.categories : []);
const tagList = page.tags && page.tags.toArray ? page.tags.toArray() : (Array.isArray(page.tags) ? page.tags : []);
const articleSummary = page.summary || page.description || (page.excerpt ? strip_html(page.excerpt).trim() : '');
const tocContent = page.toc === false ? '' : toc(page.content, { class: 'article-toc-list', list_number: false, min_depth: 1, max_depth: 3 });
const hasToc = tocContent && tocContent.indexOf('<li') !== -1;
%>
<article class="article-shell">
  <header class="article-header">
    <p class="eyebrow">WRITEUP / ARTICLE</p>
    <h1><%= page.title %></h1>
    <div class="article-meta">
      <span><%= date(page.date, 'YYYY-MM-DD') %></span>
      <% if (page.updated) { %><span>更新于 <%= date(page.updated, 'YYYY-MM-DD') %></span><% } %>
      <% if (categoryList.length) { %>
        <span><%= categoryList.map(function(item) { return item.name; }).join(' / ') %></span>
      <% } %>
    </div>
    <% if (tagList.length) { %>
      <div class="tag-row">
        <% tagList.forEach(function(tag) { %>
          <a class="tag-pill" href="<%- url_for(tag.path) %>"># <%= tag.name %></a>
        <% }) %>
      </div>
    <% } %>
  </header>

  <% if (page.cover) { %>
    <div class="article-cover">
      <img src="<%= page.cover %>" alt="<%= page.title %>">
    </div>
  <% } %>

  <% if (articleSummary) { %>
    <section class="article-summary">
      <strong>摘要</strong>
      <p><%= articleSummary %></p>
    </section>
  <% } %>

  <% if (page.warning) { %>
    <section class="article-warning">
      <strong>说明</strong>
      <p><%= page.warning %></p>
    </section>
  <% } %>

  <div class="article-main-shell <%= hasToc ? 'with-toc' : '' %>">
    <section class="article-body">
      <%- page.content %>
    </section>

    <% if (hasToc) { %>
      <aside class="article-toc-shell">
        <div class="article-toc">
          <div class="article-toc-head">
            <p class="eyebrow">TABLE OF CONTENTS</p>
            <h3>文章目录</h3>
          </div>
          <%- tocContent %>
        </div>
      </aside>
    <% } %>
  </div>
</article>
